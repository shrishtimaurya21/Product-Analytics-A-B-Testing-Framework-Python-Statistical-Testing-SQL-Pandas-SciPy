# 3. Funnel Analysis

`funnel_analysis.py`

```python
import pandas as pd

df = pd.read_csv(
    "data/user_sessions.csv"
)

landing = len(
    df[df["Stage"]=="Landing"]
)

product = len(
    df[df["Stage"]=="Product"]
)

cart = len(
    df[df["Stage"]=="Cart"]
)

payment = len(
    df[df["Stage"]=="Payment"]
)

purchase = len(
    df[df["Stage"]=="Purchase"]
)

funnel = pd.DataFrame({
    "Stage":[
        "Landing",
        "Product",
        "Cart",
        "Payment",
        "Purchase"
    ],
    "Users":[
        landing,
        product,
        cart,
        payment,
        purchase
    ]
})

funnel["Dropoff"] = (
    1 -
    funnel["Users"] /
    funnel["Users"].shift(1)
)

funnel.to_csv(
    "outputs/funnel_metrics.csv",
    index=False
)
```

