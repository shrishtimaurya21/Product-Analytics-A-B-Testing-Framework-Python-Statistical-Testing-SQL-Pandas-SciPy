# 4. A/B Test Engine

`ab_test.py`

```python
import pandas as pd

from scipy.stats import chi2_contingency

df = pd.read_csv(
    "data/experiment_data.csv"
)

table = pd.crosstab(
    df["Variant"],
    df["Converted"]
)

chi2,p,dof,expected = (
    chi2_contingency(table)
)

print(f"P Value: {p}")

if p < 0.05:
    print(
        "Statistically Significant"
    )
else:
    print(
        "Not Significant"
    )
```

